import cv2
import numpy as np

img = cv2.imread("C:/Users/AISHMA GIRI/Desktop/watch.jpeg")

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
gray = cv2.GaussianBlur(gray,(9,9),2)

circles = cv2.HoughCircles(gray, cv2.HOUGH_GRADIENT, 1, 200,
                           param1=50, param2=40,
                           minRadius=100, maxRadius=300)

if circles is not None:
    circles = np.uint16(np.around(circles))

    # Select the largest circle (watch dial)
    largest = max(circles[0], key=lambda x: x[2])

    x, y, r = largest

    cv2.circle(img,(x,y),r,(0,255,0),3)
    cv2.putText(img,"Watch",(x-40,y-40),
                cv2.FONT_HERSHEY_SIMPLEX,0.8,(0,255,0),2)

cv2.imshow("Watch Detection",img)
cv2.waitKey(0)
cv2.destroyAllWindows()
