import cv2
import numpy as np

# Read the input image
img = cv2.imread("C:/Users/AISHMA GIRI/Pictures/Eiffel.jpg")

# Convert to grayscale
gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

# Apply a threshold for segmentation
# You can change 128 to any threshold value (0-255)
threshold_value = 128
_, segmented = cv2.threshold(gray, threshold_value, 255, cv2.THRESH_BINARY)

# Show the original and segmented images
cv2.imshow("Original Image", img)
cv2.imshow("Segmented Image", segmented)

cv2.waitKey(0)
cv2.destroyAllWindows()
